# Meta Ads MCP — environment configuration template.
# Copy to .env (or paste into Dokploy env panel) and adjust.
#
# All values are OPTIONAL except as noted in the deployment notes below.

# ---------------------------------------------------------------------------
# Write gate
# ---------------------------------------------------------------------------
# Default: false (read-only). Set to true to expose create/update/upload tools
# server-wide. Applies to ALL tenants if multi-tenant.
META_ADS_MCP_WRITE=false

# ---------------------------------------------------------------------------
# Hosted-deployment hardening (recommended for mcp.magnifito.com/meta)
# ---------------------------------------------------------------------------
# Hide the get_login_link tool. Clients arrive with a Bearer token already.
META_ADS_DISABLE_LOGIN_LINK=1
# Disable the local OAuth callback listener (only useful for `--login` on dev).
META_ADS_DISABLE_CALLBACK_SERVER=1

# ---------------------------------------------------------------------------
# Server-wide Meta auth fallback (skip for pure multi-tenant)
# ---------------------------------------------------------------------------
# Used when a request arrives WITHOUT an Authorization: Bearer header.
# For multi-tenant SaaS-style deploys, leave both empty so unauthenticated
# requests fail fast instead of leaking through a shared token.
# META_ACCESS_TOKEN=EAAB...
#
# When set, every Graph API call is signed with appsecret_proof (HMAC-SHA256
# of the access token using this secret). Strongly recommended for system-user
# tokens; required by Meta for some endpoints.
# META_APP_SECRET=

# ---------------------------------------------------------------------------
# Local OAuth flow (only useful when running outside container, --login)
# ---------------------------------------------------------------------------
# META_APP_ID=

# ---------------------------------------------------------------------------
# Account discovery (Drak/Magnifito-specific)
# ---------------------------------------------------------------------------
# Comma-separated Business Manager IDs to expand via client_ad_accounts and
# owned_ad_accounts edges in get_ad_accounts.
# META_ADS_BM_IDS=285682998480431
#
# Comma-separated extra ad-account IDs (act_xxx) to direct-fetch even when
# they don't show up via the BM edges — typical for partner-shared accounts.
# META_ADS_EXTRA_ACCOUNT_IDS=act_441611459623086

# ---------------------------------------------------------------------------
# Optional tool gates
# ---------------------------------------------------------------------------
# Expose generate_report tool.
# META_ADS_ENABLE_REPORTS=1
#
# Expose save_ad_image_locally tool. DO NOT enable in hosted containers — it
# writes to the container filesystem.
# META_ADS_ENABLE_SAVE_AD_IMAGE_LOCALLY=

# ---------------------------------------------------------------------------
# HTTP transport
# ---------------------------------------------------------------------------
# Mount path for the streamable-http endpoint. The Dockerfile defaults to
# /meta to match the Traefik route in docker-compose.yml.
# MCP_HTTP_PATH=/meta
